{
  "name": "@cloudflare/workers-oauth-provider",
  "version": "0.8.1",
  "description": "OAuth provider for Cloudflare Workers",
  "main": "dist/oauth-provider.js",
  "types": "dist/oauth-provider.d.ts",
  "author": "Kenton Varda <kenton@cloudflare.com>",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "check": "npm run typecheck && npm run test",
    "typecheck": "tsc",
    "test": "npm run test:node && npm run test:workers",
    "test:node": "vitest run --config vitest.config.ts",
    "test:workers": "vitest run --config __tests__/workers/vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "prepublishOnly": "npm run build",
    "prettier": "prettier -w ."
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@cloudflare/vitest-pool-workers": "0.18.0",
    "@cloudflare/workers-types": "4.20260702.1",
    "pkg-pr-new": "^0.0.62",
    "prettier": "^3.7.4",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/workers-oauth-provider"
  },
  "bugs": {
    "url": "https://github.com/cloudflare/workers-oauth-provider/issues"
  },
  "homepage": "https://github.com/cloudflare/workers-oauth-provider#readme"
}
