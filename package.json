{
  "name": "@cloudflare/workers-oauth-provider",
  "version": "0.8.1",
  "description": "OAuth provider for Cloudflare Workers",
  "main": "dist/oauth-provider.js",
  "types": "dist/oauth-provider.d.ts",
  "exports": {
    ".": {
      "types": "./dist/oauth-provider.d.ts",
      "import": "./dist/oauth-provider.js",
      "default": "./dist/oauth-provider.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "default": "./dist/storage/index.js"
    },
    "./storage/kv": {
      "types": "./dist/storage/kv/index.d.ts",
      "import": "./dist/storage/kv/index.js",
      "default": "./dist/storage/kv/index.js"
    },
    "./storage/d1": {
      "types": "./dist/storage/d1/index.d.ts",
      "import": "./dist/storage/d1/index.js",
      "default": "./dist/storage/d1/index.js"
    },
    "./storage/durable-object": {
      "types": "./dist/storage/durable-object/index.d.ts",
      "import": "./dist/storage/durable-object/index.js",
      "default": "./dist/storage/durable-object/index.js"
    },
    "./storage/postgres": {
      "types": "./dist/storage/postgres/index.d.ts",
      "import": "./dist/storage/postgres/index.js",
      "default": "./dist/storage/postgres/index.js"
    },
    "./storage/redis": {
      "types": "./dist/storage/redis/index.d.ts",
      "import": "./dist/storage/redis/index.js",
      "default": "./dist/storage/redis/index.js"
    },
    "./dist/oauth-provider.js": {
      "types": "./dist/oauth-provider.d.ts",
      "import": "./dist/oauth-provider.js",
      "default": "./dist/oauth-provider.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Kenton Varda <kenton@cloudflare.com>",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "check": "npm run typecheck && npm run test",
    "check:package": "node scripts/check-package.mjs",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prettier": "prettier -w ."
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@cloudflare/workers-types": "^4.20251218.0",
    "pkg-pr-new": "^0.0.62",
    "prettier": "^3.7.4",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/workers-oauth-provider"
  },
  "bugs": {
    "url": "https://github.com/cloudflare/workers-oauth-provider/issues"
  },
  "homepage": "https://github.com/cloudflare/workers-oauth-provider#readme"
}
